# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key    # Settings → API → service_role
SUPABASE_ANON_KEY=your-anon-key               # Settings → API → anon public

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PULSE_API_SECRET=your-generated-secret-here

# ─── OAuth (only needed for one-click OAuth connect — API key works without these) ───
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3001/oauth/hubspot/callback

SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:3001/oauth/salesforce/callback

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:3001/oauth/zoho/callback

DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_REDIRECT_URI=http://localhost:3001/oauth/dynamics/callback
DYNAMICS_TENANT_ID=common

# ─── Email (optional — needed for sending surveys by email) ───────────────────
# Sign up free at https://resend.com — 3,000 emails/month free
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=surveys@yourdomain.com
